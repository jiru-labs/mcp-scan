{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/Users/demo"]
    },
    "github": {
      "command": "docker",
      "args": ["run", "-i", "--rm", "ghcr.io/github/github-mcp-server"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "ghp_FAKEfixtureTOKENdoNotUse0123456789"
      }
    },
    "remote-notes": {
      "url": "https://notes.example.com/mcp",
      "env": {
        "NOTES_API_KEY": "sk-FAKEfixtureKEYdoNotUse"
      }
    }
  }
}
