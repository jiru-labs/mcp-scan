{
  "mcpServers": {
    "env-hardcoded": {
      "command": "npx",
      "args": ["-y", "@example/mcp-server"],
      "env": {
        "EXAMPLE_API_KEY": "sk-FAKEfixtureENVkeyDoNotUse0123"
      }
    },
    "args-inline": {
      "command": "npx",
      "args": [
        "-y",
        "@example/mcp-remote",
        "--api-key=ghp_FAKEfixtureARGtokenDoNotUse0123",
        "--verbose"
      ]
    },
    "url-inline": {
      "url": "https://mcp.example.com/sse?api_key=sk-FAKEfixtureURLkeyDoNotUse0123&region=eu"
    },
    "env-referenced": {
      "command": "npx",
      "args": ["-y", "@example/mcp-server"],
      "env": {
        "EXAMPLE_API_KEY": "${EXAMPLE_API_KEY}"
      }
    },
    "url-referenced": {
      "url": "https://mcp.example.com/sse?api_key=${EXAMPLE_API_KEY}"
    }
  }
}
